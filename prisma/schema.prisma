generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model ai_order_logs {
  id               Int       @id @default(autoincrement())
  user_id          Int?
  input_text       String
  ai_result        Json?
  status           String?   @default("success") @db.VarChar(30)
  error_message    String?
  created_order_id Int?
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  orders           orders?   @relation(fields: [created_order_id], references: [id], onUpdate: NoAction)
  users            users?    @relation(fields: [user_id], references: [id], onUpdate: NoAction)
}

model branches {
  id             Int              @id @default(autoincrement())
  name           String           @db.VarChar(150)
  phone          String?          @db.VarChar(20)
  address        String?
  status         Boolean?         @default(true)
  created_at     DateTime?        @default(now()) @db.Timestamp(6)
  updated_at     DateTime?        @default(now()) @db.Timestamp(6)
  dining_tables  dining_tables[]
  inventory_logs inventory_logs[]
  orders         orders[]
  stock_imports  stock_imports[]
  users          users[]
}

model categories {
  id          Int        @id @default(autoincrement())
  name        String     @db.VarChar(100)
  description String?
  status      Boolean?   @default(true)
  created_at  DateTime?  @default(now()) @db.Timestamp(6)
  updated_at  DateTime?  @default(now()) @db.Timestamp(6)
  products    products[]
}

model customers {
  id          Int       @id @default(autoincrement())
  full_name   String    @db.VarChar(100)
  phone       String?   @db.VarChar(20)
  email       String?   @db.VarChar(100)
  address     String?
  total_spent Decimal?  @default(0) @db.Decimal(12, 2)
  debt        Decimal?  @default(0) @db.Decimal(12, 2)
  point       Int?      @default(0)
  note        String?
  status      Boolean?  @default(true)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  updated_at  DateTime? @default(now()) @db.Timestamp(6)
  orders      orders[]

  @@index([phone], map: "idx_customers_phone")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model dining_tables {
  id         Int       @id @default(autoincrement())
  branch_id  Int?
  table_name String    @db.VarChar(50)
  status     String?   @default("available") @db.VarChar(30)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  branches   branches? @relation(fields: [branch_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  orders     orders[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model inventory_logs {
  id              Int       @id @default(autoincrement())
  product_id      Int?
  user_id         Int?
  branch_id       Int?
  type            String    @db.VarChar(30)
  quantity        Int
  before_quantity Int?      @default(0)
  after_quantity  Int?      @default(0)
  reference_type  String?   @db.VarChar(50)
  reference_id    Int?
  note            String?
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  branches        branches? @relation(fields: [branch_id], references: [id], onUpdate: NoAction)
  products        products? @relation(fields: [product_id], references: [id], onUpdate: NoAction)
  users           users?    @relation(fields: [user_id], references: [id], onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model order_item_toppings {
  id            Int          @id @default(autoincrement())
  order_item_id Int?
  topping_id    Int?
  topping_name  String       @db.VarChar(100)
  price         Decimal      @default(0) @db.Decimal(12, 2)
  created_at    DateTime?    @default(now()) @db.Timestamp(6)
  order_items   order_items? @relation(fields: [order_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  toppings      toppings?    @relation(fields: [topping_id], references: [id], onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model order_items {
  id                  Int                   @id @default(autoincrement())
  order_id            Int?
  product_id          Int?
  option_id           Int?
  product_name        String                @db.VarChar(150)
  product_code        String?               @db.VarChar(50)
  option_name         String?               @db.VarChar(100)
  option_extra_price  Decimal?              @default(0) @db.Decimal(12, 2)
  quantity            Int
  cost_price          Decimal?              @default(0) @db.Decimal(12, 2)
  selling_price       Decimal               @db.Decimal(12, 2)
  total               Decimal               @db.Decimal(12, 2)
  note                String?
  created_at          DateTime?             @default(now()) @db.Timestamp(6)
  order_item_toppings order_item_toppings[]
  product_options     product_options?      @relation(fields: [option_id], references: [id], onUpdate: NoAction)
  orders              orders?               @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products            products?             @relation(fields: [product_id], references: [id], onUpdate: NoAction)

  @@index([order_id], map: "idx_order_items_order_id")
  @@index([product_id], map: "idx_order_items_product_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model orders {
  id             Int             @id @default(autoincrement())
  order_code     String          @unique @db.VarChar(50)
  customer_id    Int?
  user_id        Int?
  branch_id      Int?
  table_id       Int?
  order_type     String?         @default("takeaway") @db.VarChar(30)
  total_amount   Decimal         @default(0) @db.Decimal(12, 2)
  discount       Decimal?        @default(0) @db.Decimal(12, 2)
  final_amount   Decimal         @default(0) @db.Decimal(12, 2)
  paid_amount    Decimal?        @default(0) @db.Decimal(12, 2)
  debt_amount    Decimal?        @default(0) @db.Decimal(12, 2)
  payment_method String?         @default("cash") @db.VarChar(30)
  payment_status String?         @default("paid") @db.VarChar(30)
  status         String?         @default("completed") @db.VarChar(30)
  note           String?
  created_at     DateTime?       @default(now()) @db.Timestamp(6)
  updated_at     DateTime?       @default(now()) @db.Timestamp(6)
  ai_order_logs  ai_order_logs[]
  order_items    order_items[]
  branches       branches?       @relation(fields: [branch_id], references: [id], onUpdate: NoAction)
  customers      customers?      @relation(fields: [customer_id], references: [id], onUpdate: NoAction)
  dining_tables  dining_tables?  @relation(fields: [table_id], references: [id], onUpdate: NoAction)
  users          users?          @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@index([order_code], map: "idx_orders_code")
  @@index([created_at], map: "idx_orders_created_at")
  @@index([status], map: "idx_orders_status")
  @@index([order_type], map: "idx_orders_type")
}

model product_aliases {
  id         Int       @id @default(autoincrement())
  product_id Int?
  alias_name String    @db.VarChar(150)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  products   products? @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([alias_name], map: "idx_product_aliases_name")
  @@index([product_id], map: "idx_product_aliases_product_id")
}

model product_options {
  id          Int           @id @default(autoincrement())
  product_id  Int?
  option_name String        @db.VarChar(100)
  extra_price Decimal?      @default(0) @db.Decimal(12, 2)
  status      Boolean?      @default(true)
  created_at  DateTime?     @default(now()) @db.Timestamp(6)
  order_items order_items[]
  products    products?     @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model products {
  id                 Int                  @id @default(autoincrement())
  category_id        Int?
  code               String               @unique @db.VarChar(50)
  name               String               @db.VarChar(150)
  image              String?
  product_type       String?              @default("drink") @db.VarChar(30)
  unit               String?              @default("ly") @db.VarChar(30)
  cost_price         Decimal?             @default(0) @db.Decimal(12, 2)
  selling_price      Decimal              @db.Decimal(12, 2)
  stock_quantity     Int?                 @default(0)
  min_stock          Int?                 @default(5)
  allow_topping      Boolean?             @default(false)
  allow_size         Boolean?             @default(false)
  description        String?
  status             Boolean?             @default(true)
  created_at         DateTime?            @default(now()) @db.Timestamp(6)
  updated_at         DateTime?            @default(now()) @db.Timestamp(6)
  inventory_logs     inventory_logs[]
  order_items        order_items[]
  product_aliases    product_aliases[]
  product_options    product_options[]
  categories         categories?          @relation(fields: [category_id], references: [id], onUpdate: NoAction)
  stock_import_items stock_import_items[]

  @@index([category_id], map: "idx_products_category_id")
  @@index([code], map: "idx_products_code")
  @@index([name], map: "idx_products_name")
  @@index([product_type], map: "idx_products_type")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model stock_import_items {
  id            Int            @id @default(autoincrement())
  import_id     Int?
  product_id    Int?
  quantity      Int
  cost_price    Decimal        @db.Decimal(12, 2)
  total         Decimal        @db.Decimal(12, 2)
  created_at    DateTime?      @default(now()) @db.Timestamp(6)
  stock_imports stock_imports? @relation(fields: [import_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products      products?      @relation(fields: [product_id], references: [id], onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model stock_imports {
  id                 Int                  @id @default(autoincrement())
  import_code        String               @unique @db.VarChar(50)
  supplier_id        Int?
  user_id            Int?
  branch_id          Int?
  total_amount       Decimal?             @default(0) @db.Decimal(12, 2)
  note               String?
  status             String?              @default("pending") @db.VarChar(30)
  created_at         DateTime?            @default(now()) @db.Timestamp(6)
  updated_at         DateTime?            @default(now()) @db.Timestamp(6)
  stock_import_items stock_import_items[]
  branches           branches?            @relation(fields: [branch_id], references: [id], onUpdate: NoAction)
  suppliers          suppliers?           @relation(fields: [supplier_id], references: [id], onUpdate: NoAction)
  users              users?               @relation(fields: [user_id], references: [id], onUpdate: NoAction)
}

model suppliers {
  id            Int             @id @default(autoincrement())
  name          String          @db.VarChar(150)
  phone         String?         @db.VarChar(20)
  email         String?         @db.VarChar(100)
  address       String?
  note          String?
  status        Boolean?        @default(true)
  created_at    DateTime?       @default(now()) @db.Timestamp(6)
  updated_at    DateTime?       @default(now()) @db.Timestamp(6)
  stock_imports stock_imports[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model toppings {
  id                  Int                   @id @default(autoincrement())
  name                String                @db.VarChar(100)
  price               Decimal               @default(0) @db.Decimal(12, 2)
  status              Boolean?              @default(true)
  created_at          DateTime?             @default(now()) @db.Timestamp(6)
  order_item_toppings order_item_toppings[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model users {
  id             Int              @id @default(autoincrement())
  branch_id      Int?
  full_name      String           @db.VarChar(100)
  email          String           @unique @db.VarChar(100)
  phone          String?          @db.VarChar(20)
  password       String
  role           String           @default("staff") @db.VarChar(30)
  status         Boolean?         @default(true)
  created_at     DateTime?        @default(now()) @db.Timestamp(6)
  updated_at     DateTime?        @default(now()) @db.Timestamp(6)
  ai_order_logs  ai_order_logs[]
  face_profiles  face_profiles[]
  inventory_logs inventory_logs[]
  orders         orders[]
  stock_imports  stock_imports[]
  branches       branches?        @relation(fields: [branch_id], references: [id], onUpdate: NoAction)

  @@index([email], map: "idx_users_email")
}

model face_profiles {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  descriptor Json
  status     Boolean?  @default(true)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_face_profiles_user_id")
}
